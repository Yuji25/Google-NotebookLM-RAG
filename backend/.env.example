PORT=apna_port_dalo
QDRANT_URL=apna_qdrant_url
QDRANT_API_KEY=apna_qdrant_key
API_KEY=apna_llm_key
BASE_URL=apna_base_url
COLLECTION_NAME=apna_collections_name
MODEL=apna_model_name

# ---- Corrective RAG / retrieval tuning ----
RETRIEVAL_K=5
MAX_CONTEXT_TOKENS=8000      # Groq (12K TPM) keep ~8000. Gemma(unlimited)/Gemini(250K) can go 20000+
ENABLE_CORRECTIVE_RAG=true   # score-gated judge -> rewrite -> retry loop (set false for plain RAG)
ENABLE_HYDE=false            # extra request per question; enable only with RPM headroom
MAX_CORRECTION_RETRIES=1
RELEVANCE_HIGH=0.5           # top score >= this -> clearly relevant, accept without LLM judge (saves a request)
RELEVANCE_LOW=0.15           # top score <= this -> near-zero garbage, reject without judge. Grey zone -> LLM judge decides
